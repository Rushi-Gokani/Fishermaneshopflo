{%- comment -%}
  Product Card Snippet - New Design
  Features: Best Seller badge, heart icon, swipeable image dots, Buy Now button (#40C4FF)
  Fixed height cards with title truncation

  @param {object} product - The product object
  @param {object} children - The children of the product card
  @param {object} [block] - The block object
{%- endcomment -%}

{% assign block_settings = block.settings %}
{% assign accent_color = '#40C4FF' %}
{% assign media_count = product.media | size %}

{% liquid
  assign has_multiple_media = false
  if media_count > 1
    assign has_multiple_media = true
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign sold_out = false
  unless product.available
    assign sold_out = true
  endunless

  assign show_badge = false
  if product.tags contains 'best-seller' or product.tags contains 'Best Seller'
    assign show_badge = true
  endif

  assign discount_percent = 0
  if on_sale and product.compare_at_price > 0
    assign price_difference = product.compare_at_price | minus: product.price
    assign discount_percent = price_difference | times: 100 | divided_by: product.compare_at_price
  endif
%}

{% style %}
  .pc-card {
    background-color: #FFFFFF;
    border: 1px solid #F0F0F0;
    border-radius: 10px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    height: 100%;
    position: relative;
    content-visibility: auto;
    contain-intrinsic-size: 0 520px;
  }

  .pc-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .pc-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-shrink: 0;
  }

  .pc-badge {
    background-color: #FFFFFF;
    color: #000000;
    font-size: 14px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 10px;
  }

  .pc-img-wrap {
    position: relative;
    margin-bottom: 8px;
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
    z-index: 2;
  }

  .pc-slider {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
  }

  .pc-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: transparent;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 1;
    visibility: visible;
    transition: background-color 0.3s ease, transform 0.3s ease;
    z-index: 10;
    box-shadow: none;
  }

  .pc-arrow:hover {
    background-color: rgba(0, 0, 0, 0.05);
    box-shadow: none;
    transform: translateY(-50%) scale(1.1);
  }

  .pc-arrow-prev {
    left: 8px;
  }

  .pc-arrow-next {
    right: 8px;
  }

  .pc-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .pc-arrow svg {
    width: 16px;
    height: 16px;
    color: #000000;
  }

  .pc-slider-ct {
    display: flex;
    transition: transform 0.3s ease;
    cursor: grab;
    width: 100%;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
  }

  .pc-slider-ct img {
    -webkit-user-drag: none;
    user-drag: none;
    pointer-events: none;
  }

  .pc-slider-ct.dragging {
    cursor: grabbing;
    transition: none;
  }

  .pc-slider-ct > * {
    flex: 0 0 100%;
    display: block;
  }

  .pc-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    flex-shrink: 0;
    user-select: none;
    -webkit-user-select: none;
    border-radius: 10px;
  }

  .pc-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
    position: relative;
    z-index: 2;
  }

  .pc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #CCCCCC;
    transition: background-color 0.3s ease;
    cursor: pointer;
  }

  .pc-dot.active {
    background-color: {{ accent_color }};
  }

  .pc-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    min-height: 0;
  }

  .pc-brand {
    font-size: 12px;
    font-weight: 400;
    color: {{ accent_color }};
    margin: 0;
    flex-shrink: 0;
  }

  .pc-brand-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    z-index: 2;
  }

  .pc-brand-link:hover {
    opacity: 0.85;
  }

  .pc-title {
    font-size: 14px;
    font-weight: 700;
    font-family: var(--font-heading--family);
    color: #000000;
    margin: 0;
    text-align: right;
    text-transform: uppercase;
    line-height: 1.3;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pc-title a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-align: left;
  }

  .pc-title a::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .pc-title a:hover {
    opacity: 0.7;
  }

  .pc-price {
    font-size: 14px;
    font-weight: 400;
    color: #000000;
    margin: 0;
    flex-shrink: 0;
  }

  .pc-price .compare-price {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
  }

  .pc-single-link {
    display: block;
    border-radius: 10px;
    overflow: hidden;
  }

  .pc-discount {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: #FF3B30;
    color: #FFFFFF;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 11;
    border-radius: 10px;
    box-shadow: 0 4px 12px rgba(255, 59, 48, 0.3);
  }

  @media screen and (max-width: 749px) {
    .pc-discount {
      top: 6px;
      right: 6px;
      font-size: 10px;
      padding: 4px 8px;
      border-radius: 8px;
    }
  }

  .pc-buy-btn {
    width: 100%;
    background-color: {{ accent_color }};
    color: #000000;
    font-size: 16px;
    font-weight: 700;
    border: none;
    border-radius: 10px;
    padding: 16px;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
    margin-top: 8px;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .pc-buy-btn:hover:not(:disabled) {
    opacity: 0.9;
    transform: scale(1.02);
  }

  .pc-buy-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 749px) {
    .pc-title {
      font-size: 14px;
    }

    .pc-buy-btn {
      font-size: 14px;
      padding: 12px;
    }

    .pc-arrow {
      display: none !important;
    }

    .pc-slider-ct {
      touch-action: pan-y pan-x;
    }
  }
{% endstyle %}

<card-slider class="pc-card" data-total-slides="{{ product.media.size | default: 1 | at_most: 3 }}">
  <!-- Top Section: Badge -->
  {% if show_badge %}
    <div class="pc-top" style="margin-bottom: 4px;">
      <span class="pc-badge">Best Seller</span>
    </div>
  {% endif %}

  <!-- Image Section with Swipeable Slider -->
  <div class="pc-img-wrap">
    {%- assign is_best_seller = false -%}
    {%- for collection in product.collections limit: 5 -%}
      {%- if collection.title == 'Best Sellers' -%}
        {%- assign is_best_seller = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    
    {%- if is_best_seller -%}
      <img src="https://cdn.shopify.com/s/files/1/0665/2887/0715/files/1722944964203-352234792-BADGES1.png?v=1722945193" 
           alt="Best Seller"
           class="best-seller-badge-image"
           style="position: absolute; top: 10px; left: 10px; z-index: 5; width: 70px; height: auto;"
           loading="lazy" decoding="async" width="70" height="70">
    {%- endif -%}
    {% if on_sale and discount_percent > 0 %}
      <div class="pc-discount">
        Save {{ discount_percent | round }}%
      </div>
    {% endif %}

    {% if has_multiple_media %}
      <div class="pc-slider">
        <!-- Previous Arrow -->
        <button
          class="pc-arrow pc-arrow-prev"
          aria-label="Previous image"
          data-arrow-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        </button>

        <!-- Next Arrow -->
        <button
          class="pc-arrow pc-arrow-next"
          aria-label="Next image"
          data-arrow-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </button>

        <div class="pc-slider-ct" data-slider data-product-url="{{ product.url }}">
          {% if media_count > 0 %}
            {% for media in product.media limit: 3 %}
              {% if media.media_type == 'image' %}
                <a href="{{ product.url }}" tabindex="-1" draggable="false" class="pc-img-link">
                  <img
                    src="{{ media | image_url: width: 400 }}"
                    alt="{{ media.alt | escape }}"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                    class="pc-img"
                  >
                </a>
              {% elsif media.media_type == 'video' %}
                <video
                  class="pc-img"
                  muted
                  loop
                  playsinline
                  preload="none"
                  onclick="this.paused ? this.play() : this.pause()"
                >
                  <source src="{{ media.sources[1].url }}" type="video/mp4">
                </video>
              {% endif %}
            {% endfor %}
          {% else %}
            {{ 'product-' | append: product.id | placeholder_svg_tag: 'pc-img' }}
          {% endif %}
        </div>
      </div>

      <!-- Pagination Dots -->
      <div class="pc-dots">
        {% for media in product.media limit: 3 %}
          <span
            class="pc-dot{% if forloop.first %} active{% endif %}"
            data-dot
            data-index="{{ forloop.index | minus: 1 }}"
          ></span>
        {% endfor %}
      </div>
    {% else %}
      <a
        href="{{ product.url }}"
        class="pc-single-link"
        aria-label="{{ product.title | escape }}"
      >
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 400 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            decoding="async"
            width="400"
            height="400"
            class="pc-img"
          >
        {% else %}
          {{ 'product-' | append: product.id | placeholder_svg_tag: 'pc-img' }}
        {% endif %}
      </a>
    {% endif %}
  </div>

  <!-- Bottom Section: Brand, Title, Price, Button -->
  <div class="pc-content">
    {% if product.vendor %}
      {%- assign vendor_handle = product.vendor | handleize -%}
      <p class="pc-brand">
        <a href="{{ routes.collections_url }}/{{ vendor_handle }}" class="pc-brand-link">
          {{ product.vendor }}
        </a>
      </p>
    {% endif %}

    <h3 class="pc-title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <p class="pc-price">
      {% if on_sale %}
        <span class="sale-price">{{ product.price | money }}</span>
        <span class="compare-price">{{ product.compare_at_price | money }}</span>
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </p>

    {% comment %} {% if sold_out %}
      <button class="pc-buy-btn disabled" disabled>{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</button>
    {% else %}
      <button type="button" class="pc-buy-btn" onclick="handleAddToCart(event, {{ product.selected_or_first_available_variant.id }})">
        {{ 'Add to Cart' }}
      </button>

    {% endif %} {% endcomment %}
     <div class="pc-buy-form">
        {% if sold_out %}
          <button class="pc-buy-btn disabled" disabled>{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</button>
        {% else %}
            <button type="button" class="collectionPreorderAddToCartBtn pc-buy-btn" onclick="window.location.href='{{ product.url }}'">
              {{ 'View product' }}
            </button>
        {% endif %}
      </div>
  </div>
</card-slider>

<script>
  if (typeof handleAddToCart !== 'function') {
    function handleAddToCart(event, variantId) {
      event.preventDefault();
      event.stopPropagation();
      
      const button = event.currentTarget;
      const originalText = button.textContent;
      button.textContent = 'Adding...';
      button.disabled = true;

      const sections = [];
      document.querySelectorAll('cart-items-component').forEach(el => {
          if (el.dataset.sectionId) sections.push(el.dataset.sectionId);
      });

      const formData = {
       'items': [{
        'id': variantId,
        'quantity': 1
        }],
        'sections': sections,
        'sections_url': window.location.pathname
      };

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      })
      .then(response => {
        return response.json();
      })
      .then(data => {
        const eventDetail = {
            resource: data, 
            sourceId: 'product-card', 
            data: {
                source: 'product-card',
                itemCount: 1, 
                sections: data.sections
            }
        };

        document.dispatchEvent(new CustomEvent('cart:update', { 
            bubbles: true, 
            detail: eventDetail 
        }));

        document.dispatchEvent(new CustomEvent('ajaxProduct:added', {
            bubbles: true,
            detail: eventDetail
        }));

        const cartDrawer = document.querySelector('cart-drawer-component');
        if (cartDrawer && typeof cartDrawer.open === 'function') {
          handleFloCartBtn();
        }

        button.textContent = 'Added';
        setTimeout(() => {
          button.textContent = originalText;
          button.disabled = false;
        }, 2000);
      })
      .catch((error) => {
        console.error('Error:', error);
        button.textContent = originalText;
        button.disabled = false;
      });
    }
  }
</script>
