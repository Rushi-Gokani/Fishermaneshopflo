{% schema %}
{
  "name": "Custom Header",
  "class": "header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Top Bar Settings"
    },
    {
      "type": "checkbox",
      "id": "show_top_bar",
      "label": "Show Top Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "top_bar_text",
      "label": "Left Text",
      "default": "Free shipping on orders over Ã¢â€šÂ¬50"
    },
    {
      "type": "link_list",
      "id": "top_bar_menu",
      "label": "Top Bar Right Menu"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "color",
      "id": "top_bar_bg",
      "label": "Top Bar Background",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "top_bar_text_color",
      "label": "Top Bar Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Main Header Settings"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "header_text",
      "label": "Header Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Logo Width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Categories Button"
    },
    {
      "type": "text",
      "id": "categories_label",
      "label": "Button Label",
      "default": "Categories"
    },
    {
      "type": "color",
      "id": "categories_bg",
      "label": "Button Background",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "categories_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main Menu"
    },
    {
      "type": "text",
      "id": "badge_items",
      "label": "Menu Items with Badge (comma separated)",
      "default": "Offers, Sale",
      "info": "Case sensitive. Example: Offers, Sale"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "HOT!"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#ff4500"
    },
    {
      "type": "header",
      "content": "Sidebar Settings"
    },
    {
      "type": "color",
      "id": "sidebar_bg",
      "label": "Sidebar Background",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "sidebar_text",
      "label": "Sidebar Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "sidebar_active_bg",
      "label": "Active Item Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "sidebar_active_text",
      "label": "Active Item Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Right Icons"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show Currency Selector",
      "default": true
    },
  ],
  "blocks": [
    {
      "type": "category_group",
      "name": "Category Group",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Sidebar Heading",
          "default": "Accessories"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Sidebar Link"
        },
        {
          "type": "header",
          "content": "Column 1"
        },
        {
          "type": "text",
          "id": "menu_1_heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu_1",
          "label": "Menu"
        },
        {
          "type": "header",
          "content": "Column 2"
        },
        {
          "type": "text",
          "id": "menu_2_heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu_2",
          "label": "Menu"
        },
        {
          "type": "header",
          "content": "Column 3"
        },
        {
          "type": "text",
          "id": "menu_3_heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu_3",
          "label": "Menu"
        },
        {
          "type": "header",
          "content": "Promo Card"
        },
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "promo_title",
          "label": "Title",
          "default": "TVs & Home Theater"
        },
        {
          "type": "text",
          "id": "promo_subtitle",
          "label": "Subtitle",
          "default": "Up to 30% off!"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ]
}
{% endschema %}

{% liquid
  assign mobile_logo_width = section.settings.logo_width | times: 0.65 | round
  assign enable_cart_drawer = false
  if settings.cart_type == 'drawer' and template.name != 'cart'
    assign enable_cart_drawer = true
  endif
  assign category_blocks = section.blocks | where: 'type', 'category_group'
%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');

  .header-section {
    z-index: 5001 !important;
  }

  .custom-top-bar,
  .custom-header-section,
  .mobile-drawer {
    font-family: 'Space Grotesk', sans-serif;
    letter-spacing: -0.01em;
  }


  /* Top Bar */
  .custom-top-bar {
    background: #0f172a;
    color: #94a3b8;
    font-size: 12px;
    font-weight: 500;
    text-transform: none;
    padding: 8px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .top-bar-left { font-weight: 600; }
  .top-bar-right, .top-bar-menu, .top-bar-social { 
    display: flex; 
    align-items: center; 
    gap: 20px; 
  }
  .top-bar-menu { list-style: none; padding: 0; margin: 0; gap: 15px; }
  .top-bar-menu a { color: inherit; text-decoration: none; transition: color 0.2s; }
  .top-bar-menu a:hover { color: #40c4ff; }
  .top-bar-social a { color: #94a3b8; transition: color 0.2s; }
  .top-bar-social a:hover { color: #40c4ff; }
  .top-bar-social svg { width: 14px; height: 14px; fill: currentColor; }

  /* Main Header Section */
  .custom-header-section {
    background: #40c4ff;
    color: #0f172a;
    position: relative;
    z-index: 1000;
    padding: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .custom-header-section::before {
    content: '';
    position: absolute;
    width: 360px;
    height: 360px;
    top: -140px;
    left: -140px;
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.4;
    z-index: 0;
    background: radial-gradient(circle, #ffffff 0%, transparent 70%);
    pointer-events: none;
  }

  .custom-header-container {
    flex-wrap: nowrap;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
    height: 90px;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 1;
    overflow: visible !important; /* Allow absolute children like search results to overflow height */
  }

  .header-layout {
    flex-wrap: nowrap;
    min-width: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex: 1;
    gap: 16px; 
  }
  @media screen and (max-width: 1280px) {
    .header-layout {
    flex-wrap: nowrap;
    min-width: 0; gap: 8px; }
  }

  /* Branding */
  .header-branding {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    max-width: 250px;
  }
  .header-branding a { display: block; line-height: 0; }
  .header-branding img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
    width: 100%;
  }
  .header-logo-text {
    font-size: 24px;
    font-weight: 800;
    color: #0f172a;
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  /* Navigation Cluster (Centered) */
  .nav-cluster {
    flex-wrap: nowrap;
    min-width: 0;
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px; /* Reduced from 32px */
  }

  .categories-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .categories-btn {
    background: #ffffff;
    color: #40c4ff;
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: 10px 18px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }
  .categories-btn:hover {
    background: #f8fafc;
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
  }

  .main-nav .mega-nav__list {
    flex-wrap: nowrap;
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mega-nav__link {
    color: #0f172a;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: color 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
    white-space: nowrap; 
  }
  @media screen and (max-width: 1280px) {
    .mega-nav__link { font-size: 11px; }
    .main-nav .mega-nav__list {
    flex-wrap: nowrap; gap: 16px; }
  }
  .mega-nav__link:hover { color: #000000; opacity: 1; }

  /* Right Icons */
  .header-icons {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  @media screen and (max-width: 1200px) {
    .header-icons { gap: 6px; }
    .icon-btn { padding: 4px; }
  }
  .icon-btn {
    background: transparent;
    border: none;
    color: #0f172a;
    cursor: pointer;
    padding: 8px;
    border-radius: 10px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    opacity: 0.9;
  }
  .icon-btn:hover {
    color: #000;
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
  }
   .icon-btn svg { width: 22px; height: 22px; stroke: currentColor; stroke-width: 2; fill: none; }
  .header-actions__cart-icon {
    position: absolute;
    top: -2px;
    right: -2px;
    transform: scale(0.8);
  }
  .cart-count-bubble { background-color: #ffffff; color: #40c4ff; }

  /* Account button responsive */
  .header-icons .icon-btn[href*="/account"] {
    display: flex;
  }
  
  @media (max-width: 1024px) {
    .header-icons .icon-btn[href*="/account"] {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      min-width: 44px;
      min-height: 44px;
    }
    
    /* Mobile specific styling for all header icons */
    .header-mobile .icon-btn {
      min-width: 44px;
      min-height: 44px;
      padding: 8px;
    }
  }

  /* Megamenu Dropdown */
  .categories-dropdown {
    position: absolute;
    top: 100%; /* Position directly below */
    left: 0;
    transform: none;
    background: transparent; /* Transparent container */
    padding-top: 20px; /* Physical bridge for the gap */
    display: none;
    width: 850px;
    z-index: 1001;
  }
  
  .categories-dropdown-inner {
    background: #ffffff;
    backdrop-filter: blur(20px);
    color: #0f172a;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.15);
    border-radius: 20px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    display: flex;
    width: 100%;
  }

  /* .categories-dropdown::before removed safely */
  .categories-wrapper:hover .categories-dropdown { display: flex; }

  .dropdown-sidebar {
    background: #f8fafc;
    width: 240px;
    padding: 15px 0;
    border-right: 1px solid rgba(0, 0, 0, 0.05);
  }
  .sidebar-item {
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    color: #64748b;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .sidebar-item.active, .sidebar-item:hover { 
    background: rgba(64, 196, 255, 0.1); 
    color: #40c4ff; 
    border-left: 3px solid #40c4ff; /* Active indicator */
  }

  .dropdown-content-area { flex: 1; min-height: 400px; background: transparent; }
  .custom-mega-panel { display: none; padding: 30px; justify-content: flex-start; gap: 30px; width: 100%; position: relative; min-height: 400px; }
  .menus-group { display: flex; gap: 30px; flex: 1; }
  .custom-mega-panel.active { display: flex; }
  
  .panel-column { 
    flex: 0 0 auto; 
    width: 220px; 
    border-right: 1px solid #e2e8f0; 
    padding-right: 30px;
  }

  .panel-column h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: #40c4ff; margin-bottom: 15px; }
  .panel-column ul { list-style: none; padding: 0; margin: 0; }
  .panel-column li { margin-bottom: 8px; }
  .panel-column a { text-decoration: none; color: #0f172a; font-size: 14px; font-weight: 500; transition: color 0.2s; }
  .panel-column a:hover { color: #40c4ff; }

  /* Custom Hover Dropdown for Sub-menus */
  .custom-mega-sub-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 220px;
    position: relative;
  }
  .custom-mega-sub-item a {
    flex: 1;
    padding: 6px 0;
    text-decoration: none;
    color: #0f172a;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .submenu-toggle-btn {
    background: transparent;
    border: none;
    padding: 6px 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    transition: all 0.2s;
    border-radius: 4px;
  }
  .submenu-toggle-btn:hover {
    background: rgba(64, 196, 255, 0.1);
    color: #40c4ff;
  }
  .custom-mega-sub-item.is-active .submenu-toggle-btn {
    color: #40c4ff;
  }
  .custom-mega-sub-item a svg {
    transition: transform 0.2s ease;
  }
  .custom-mega-sub-item.is-active > a {
    color: #40c4ff;
  }
  .custom-mega-sub-item.is-active .submenu-toggle-btn svg {
    transform: rotate(90deg);
  }
  .custom-mega-submenu {
    display: none;
    position: absolute;
    left: 240px;
    top: -10px;
    bottom: auto;
    width: 330px;
    list-style: none;
    padding: 15px 0;
    margin: 0;
    z-index: 10;
    background: #ffffff;
  }
  .custom-mega-submenu::before {
    content: '';
    position: absolute;
    left: -40px;
    top: 0;
    bottom: 0;
    width: 40px;
    background: transparent;
  }
  .custom-mega-submenu li {
    margin-bottom: 12px;
  }
  .submenu-heading {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #40c4ff;
    margin-bottom: 20px !important;
    font-weight: 700;
  }
  .submenu-heading a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .submenu-heading a:hover {
    opacity: 0.8;
  }
  .custom-mega-submenu a {
    font-size: 14px;
    font-weight: 500;
    color: #64748b;
    transition: color 0.2s;
  }
  .custom-mega-submenu a:hover {
    color: #40c4ff;
  }
  .custom-mega-sub-item:hover > .custom-mega-submenu,
  .custom-mega-sub-item.is-active > .custom-mega-submenu {
    display: block;
    animation: fadeInCustom 0.2s ease-out forwards;
  }
  @keyframes fadeInCustom {
    from { opacity: 0; transform: translateX(-5px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Mobile */
  .header-mobile { display: none; width:100%; align-items: center; justify-content: space-between; height: 70px; padding: 0 20px; }
  .header-mobile .header-branding { max-width: 90px; }
  .header-mobile .header-branding img { max-width: 100%; height: auto; }
  
  .header-mobile .header-icons {
    display: flex;
    gap: 8px;
  }
  
  @media (max-width: 1024px) {
    .header-layout {
    flex-wrap: nowrap;
    min-width: 0; display: none; }
    .header-mobile { display: flex; }
    .custom-header-container {
    flex-wrap: nowrap; height: auto; padding: 0; }
    
    /* Ensure account icon is visible in mobile view */
    .header-icons .icon-btn {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
  }

  /* Premium Mobile Drawer */
  .mobile-drawer {
    position: fixed; 
    top: 0; 
    left: -100%; 
    width: 85%; 
    max-width: 400px;
    height: 100%; 
    background: #ffffff; 
    z-index: 2001; 
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); 
    padding: 0;
    border-right: 1px solid rgba(0,0,0,0.05);
    box-shadow: 20px 0 50px rgba(0,0,0,0.1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 0 20px 20px 0;
  }
  .mobile-drawer.active { left: 0; }

  /* Premium Header */
  .mobile-drawer__header { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 24px 30px; 
    background: linear-gradient(to right, #f8fafc, #ffffff);
    border-bottom: 1px solid #f1f5f9;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .mobile-drawer__header .header-logo-text { font-size: 22px; font-weight: 800; color: #0f172a; }

  .mobile-drawer__close { 
    background: #f1f5f9;
    border: none; 
    color: #64748b; 
    cursor: pointer; 
    width: 36px; 
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .mobile-drawer__close:hover { background: #e2e8f0; color: #0f172a; }

  /* Navigation Area */
  .mobile-drawer__nav { padding: 10px 0; }
  .mobile-drawer__list { list-style: none; padding: 0; margin: 0; }
  
  .mobile-drawer__item {
    border-bottom: 1px solid #f8fafc;
    padding: 0 30px;
    transition: background 0.2s;
  }
  .mobile-drawer__item:last-child { border-bottom: none; }

  .mobile-drawer__link { 
    color: #334155; 
    text-decoration: none; 
    font-size: 16px; 
    font-weight: 600; 
    display: block; 
    padding: 18px 0; 
    transition: color 0.2s; 
    flex: 1;
    letter-spacing: -0.01em;
  }
  .mobile-drawer__link:hover { color: #40c4ff; }

  /* Premium Toggle Button */
  .mobile-drawer__submenu-trigger {
    width: 36px !important; 
    height: 36px !important;
    background: #f1f5f9 !important; 
    color: #64748b;
    border: none !important;
    border-radius: 10px !important;
    margin-left: 8px;
    flex-shrink: 0;
    transition: all 0.3s ease;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer;
  }
  .mobile-drawer__submenu-trigger:hover {
    background: #e2e8f0 !important;
  }
  .mobile-drawer__submenu-trigger svg { width: 14px; height: 14px; stroke-width: 2.5px; transition: transform 0.3s ease; }

  /* Submenu Styling */
  .mobile-drawer__submenu {
    display: none;
    background: #ffffff;
    margin: 0 -20px;
    padding: 8px 20px 12px;
    border-top: 1px solid #f1f5f9;
    border-bottom: 1px solid #f1f5f9;
  }
  .mobile-drawer__submenu.active { display: block; animation: slideDown 0.3s ease-out forwards; }
  
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mobile-drawer__submenu .mobile-drawer__item { padding: 0; border: none; }
  .mobile-drawer__submenu .mobile-drawer__link {
    font-size: 14px;
    padding: 10px 0 10px 16px;
    font-weight: 500;
    color: #64748b;
    border-left: 2px solid transparent;
    transition: all 0.2s;
  }
  .mobile-drawer__submenu .mobile-drawer__link:hover {
    color: #0f172a;
    border-left-color: #40c4ff;
    background: linear-gradient(to right, rgba(64,196,255,0.05), transparent);
  }

  .mobile-drawer__submenu--nested {
    margin: 0 -20px;
    padding: 6px 20px 8px;
    background: #f8fafc;
  }

  .mobile-drawer__submenu-trigger--child {
    width: 32px !important;
    height: 32px !important;
    background: #f1f5f9 !important;
    border-radius: 8px !important;
  }

  .mobile-drawer__submenu-trigger--child svg {
    width: 12px !important;
    height: 12px !important;
  }

  /* Header Search Inline */
  .header-search-container {
    flex: 0 1 240px; 
    min-width: 150px;
    margin: 0 10px; 
    position: relative;
    z-index: 1002;
    overflow: visible !important; /* Ensure dropdown is not clipped */
  }
  @media screen and (max-width: 1400px) {
    .header-search-container { flex: 0 1 200px; }
  }
  @media screen and (max-width: 1200px) {
    .header-search-container { flex: 0 1 140px; }
    .header-search-input::placeholder { opacity: 0; visibility: hidden; }
  }

  @media screen and (max-width: 1023px) {
    .header-search-container {
      flex: 1 1 100%;
      margin: 10px 0 0 0;
    }
  }
  .header-search-form {
    display: flex;
    align-items: center;
    background: #ffffff;
    border-radius: 14px;
    padding: 2px 6px 2px 12px; /* Adjusted padding-left for balance after category removal */
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.4);
    transition: all 0.3s ease;
    /* overflow: hidden removed to ensure no clipping of children if they move slightly */
  }
  .header-search-form:focus-within {
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    transform: translateY(-1px);
    border-color: #40c4ff;
  }

  .header-search-input {
    flex: 1;
    min-width: 0; /* Important: allow shrinking below default browser width */
    border: none;
    background: transparent;
    padding: 10px 0;
    font-size: 14px;
    font-weight: 500;
    color: #0f172a;
    outline: none;
  }
  .header-search-input::placeholder {
    color: #94a3b8;
  }
  .header-search-submit {
    background: #40c4ff;
    color: #ffffff;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
    margin-left: 8px;
  }
  .header-search-submit:hover {
    background: #00b0ff;
  }
  .header-search-submit svg {
    width: 18px;
    height: 18px;
  }

  /* Predictive Search Results Inline */
  .predictive-search-results-inline {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 450px; /* Increased fixed width */
    max-width: 90vw; /* Responsive constraint */
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    display: none;
    max-height: 450px;
    overflow-y: auto;
    animation: fadeInScale 0.2s ease-out;
    z-index: 10000; /* Very high z-index to appear above everything else */
    left: auto; /* Reset left if it was inheriting */
  }
  @media screen and (max-width: 1023px) {
    .predictive-search-results-inline {
      width: 100%;
    }
  }
  .predictive-search-results-inline.has-results {
    display: block;
  }
  @keyframes fadeInScale {
    from { opacity: 0; transform: translateY(-10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .predictive-search-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 12px 20px;
    text-decoration: none;
    color: #0f172a;
    transition: background 0.2s;
    border-bottom: 1px solid #f1f5f9;
  }
  .predictive-search-item:last-child {
    border-bottom: none;
  }
  .predictive-search-item:hover {
    background: #f8fafc;
  }
  .predictive-search-item img {
    width: 44px;
    height: 44px;
    object-fit: cover;
    border-radius: 8px;
    background: #f1f5f9;
  }
  .predictive-search-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .predictive-search-item__title {
    font-weight: 600;
    font-size: 13.5px;
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .predictive-search-item__price {
    font-size: 12px;
    color: #40c4ff;
    font-weight: 700;
  }
  .predictive-search-loading, .predictive-search-no-results {
    padding: 20px;
    text-align: center;
    color: #64748b;
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .header-search-container {
      max-width: none;
      margin: 10px 20px;
      order: 3;
      width: calc(100% - 40px);
    }
    .custom-header-container {
    flex-direction: column;
      height: auto;
      padding-bottom: 15px;
    }
    .header-mobile {
      height: 60px;
    }
  }

  @media screen and (min-width: 1025px) {
    .custom-header-container, .header-layout, .nav-cluster, .main-nav .mega-nav__list {
      flex-wrap: nowrap !important;
    }
    .header-layout, .nav-cluster {
      min-width: 0 !important;
    }
  }
</style>

