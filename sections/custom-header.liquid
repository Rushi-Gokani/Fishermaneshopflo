                                          <a href="{{ grandchild_link.url }}" class="mobile-drawer__link" style="font-size: 13px; font-weight: 400; color: #94a3b8; padding-left: 36px;">{{ grandchild_link.title }}</a>
                                        </li>
                                      {% endfor %}
                                    </ul>
                                  </div>
                                {% endif %}
                              </li>
                            {% endfor %}
                          </ul>
                        </div>
                      {% endif %}
                    </li>
                  {% endfor %}
                {% endif %}

                {% if first_category_block.settings.menu_2 != blank %}
                   {% for link in first_category_block.settings.menu_2.links %}
                    <li class="mobile-drawer__item {% if link.links.size > 0 %}has-submenu{% endif %}">
                      <div style="display: flex; align-items: center; justify-content: space-between;">
                        <a href="{{ link.url }}" class="mobile-drawer__link" style="flex: 1; margin-bottom: 0;">{{ link.title }}</a>
                        {% if link.links.size > 0 %}
                          <button class="mobile-drawer__submenu-trigger" style="width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                          </button>
                        {% endif %}
                      </div>
                      {% if link.links.size > 0 %}
