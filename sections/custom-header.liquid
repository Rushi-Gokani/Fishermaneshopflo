<div class="mobile-drawer__overlay" id="mobileDrawerOverlay"></div>

  {% comment %} Search Modal Removed {% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Inline Search Logic
    const searchInputs = document.querySelectorAll('.header-search-input');
    const predictiveResultsContainers = document.querySelectorAll('.predictive-search-results-inline');

    searchInputs.forEach((searchInput, index) => {
      const predictiveResults = predictiveResultsContainers[index];
      let debounceTimer;
      let currentQuery = '';

      searchInput.addEventListener('input', function() {
        const query = this.value.trim();
        clearTimeout(debounceTimer);

        if (query.length === 0) {
          currentQuery = '';
          predictiveResults.innerHTML = '';
          predictiveResults.classList.remove('has-results');
          return;
        }

        currentQuery = query;

        debounceTimer = setTimeout(() => {
          fetchSuggestions(query, predictiveResults);
        }, 150);
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !predictiveResults.contains(e.target)) {
          predictiveResults.classList.remove('has-results');
        }
      });

      searchInput.addEventListener('focus', () => {
        if (predictiveResults.children.length > 0) {
          predictiveResults.classList.add('has-results');
        }
      });
    });

    function fetchSuggestions(query, container) {
      container.innerHTML = '<div class="predictive-search-loading">Searching...</div>';
      container.classList.add('has-results');

      const searchFields = 'title,body,product_type,tag,variants.title,vendor,variants.sku';
      const url = `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=10&resources[options][unavailable_products]=last&resources[options][fields]=${searchFields}`;

      fetch(url)
        .then(response => response.json())
        .then(data => {
          const products = data.resources && data.resources.results ? data.resources.results.products : [];
          if (products && products.length > 0) {
            renderResults(products, container, query);
          } else {
            container.innerHTML = '<div class="predictive-search-no-results">No products found for "' + escapeHtml(query) + '"</div>';
          }
        })
        .catch(error => {
          console.error('Error fetching suggestions:', error);
          container.innerHTML = '<div class="predictive-search-no-results">Error loading results.</div>';
        });
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(text));
      return div.innerHTML;
    }

    function renderResults(products, container, query) {
      let html = '';
      var searchInput = document.getElementById('HeaderSearchInput');
      products.forEach(product => {
        var highlightedTitle = highlightMatch(product.title, query);
        html += `
          <a href="${product.url}" class="predictive-search-item">
            ${product.image ? `<img src="${product.image}" alt="${escapeHtml(product.title)}">` : '<div class="predictive-search-item__placeholder"></div>'}
            <div class="predictive-search-item__info">
              <span class="predictive-search-item__title">${highlightedTitle}</span>
              <span class="predictive-search-item__price">${product.price}</span>
            </div>
          </a>
        `;
      });
      var currentQuery = searchInput ? searchInput.value : query;
      html += `
        <div style="padding: 12px 20px; text-align: center; border-top: 1px solid #f1f5f9; background: #f8fafc;">
          <a href="/search?q=${encodeURIComponent(currentQuery)}&type=product" style="display: inline-block; padding: 8px 24px; background: #40c4ff; color: #fff; font-weight: 600; font-size: 14px; text-decoration: none; border-radius: 8px; transition: background 0.2s;">View All Results</a>
        </div>
      `;
      container.innerHTML = html;
    }

    function highlightMatch(title, query) {
      if (!query || !title) return escapeHtml(title);
      var escapedTitle = escapeHtml(title);
      var escapedQuery = escapeHtml(query);
      var regex = new RegExp('(' + escapedQuery.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
      return escapedTitle.replace(regex, '<mark style="background:rgba(64,196,255,0.2);color:inherit;padding:0 2px;border-radius:2px;">$1</mark>');
    }

    const sidebarItems = document.querySelectorAll('.sidebar-item');
    const contentPanels = document.querySelectorAll('.custom-mega-panel');
    const categoriesWrapper = document.querySelector('.categories-wrapper');
    const categoriesDropdown = document.querySelector('.categories-dropdown');
    const categoriesButton = document.querySelector('.categories-btn');

    if (categoriesWrapper && categoriesDropdown) {
      let dropdownTimer;
      const openDropdown = () => {
        clearTimeout(dropdownTimer);
        categoriesWrapper.classList.add('is-open');
      };

      const closeDropdown = () => {
        clearTimeout(dropdownTimer);
        dropdownTimer = setTimeout(() => {
          categoriesWrapper.classList.remove('is-open');
          // Reset all sub-menus when the whole dropdown closes
          document.querySelectorAll('.custom-mega-sub-item.is-active').forEach(i => i.classList.remove('is-active'));
        }, 1000); // Massive 1s hold for menu stability
      };

      // Only attach listeners to wrapper (padding handles the hit area)
      categoriesWrapper.addEventListener('mouseenter', openDropdown);
      categoriesWrapper.addEventListener('mouseleave', closeDropdown);

      // Handle Click to Toggle
      categoriesButton?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (categoriesWrapper.classList.contains('is-open')) {
             closeDropdown(); // Use close function
        } else {
             openDropdown();
        }
      });
      
      // Accessibility
      categoriesButton?.addEventListener('focus', openDropdown);
      categoriesDropdown.querySelectorAll('a, button').forEach((el) => {
        el.addEventListener('focus', openDropdown);
        el.addEventListener('blur', (event) => {
            if (!categoriesDropdown.contains(event.relatedTarget)) {
                closeDropdown();
            }
        });
      });
    }

    // Mega menu hover/focus handling for premium nav
    const megaItems = document.querySelectorAll('.mega-nav__item--has-children');
    megaItems.forEach((item) => {
      const link = item.querySelector('.mega-nav__link');

      const open = () => item.classList.add('open');
      const close = () => item.classList.remove('open');

      item.addEventListener('pointerenter', open);
      item.addEventListener('pointerleave', close);

      link?.addEventListener('focus', open);
      link?.addEventListener('blur', close);

      item.querySelectorAll('a').forEach((anchor) => {
        anchor.addEventListener('focus', open);
        anchor.addEventListener('blur', (event) => {
          if (!item.contains(event.relatedTarget)) {
            close();
          }
        });
      });
    });

    let sidebarTimer;
    sidebarItems.forEach(item => {
      item.addEventListener('mouseenter', function() {
        clearTimeout(sidebarTimer);
        sidebarTimer = setTimeout(() => {
          // Remove active class from all
          sidebarItems.forEach(i => i.classList.remove('active'));
          contentPanels.forEach(p => p.classList.remove('active'));
          
          // Reset sub-item active states when switching sidebar
          document.querySelectorAll('.custom-mega-sub-item.is-active').forEach(sub => {
            sub.classList.remove('is-active');
          });

          // Add active class to current
          this.classList.add('active');
          const targetId = this.getAttribute('data-target');
          const targetPanel = document.getElementById(targetId);
          if (targetPanel) {
            targetPanel.classList.add('active');
          }
        }, 100); // 100ms intent delay for sidebar switching
      });
      
      item.addEventListener('mouseleave', () => {
        clearTimeout(sidebarTimer);
      });
    });

    // Sub-item hover: keep 3rd column submenu visible
    const subItems = document.querySelectorAll('.custom-mega-sub-item.has-submenu');
    subItems.forEach(subItem => {
      let subTimer;
      subItem.addEventListener('mouseenter', function() {
        clearTimeout(subTimer);
        subItems.forEach(s => s.classList.remove('is-active'));
        this.classList.add('is-active');
      });
      subItem.addEventListener('mouseleave', function() {
        subTimer = setTimeout(() => {
          this.classList.remove('is-active');
        }, 150);
      });
    });

    // Mobile Drawer Logic
    const mobileMenuTrigger = document.querySelector('.mobile-menu-trigger');
    const mobileDrawer = document.getElementById('mobileDrawer');
    const mobileDrawerClose = document.querySelector('.mobile-drawer__close');
    const mobileDrawerOverlay = document.getElementById('mobileDrawerOverlay');

    if (mobileMenuTrigger && mobileDrawer && mobileDrawerOverlay) {
      const openDrawer = () => {
        mobileDrawer.classList.add('active');
        mobileDrawerOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      };

      const closeDrawer = () => {
        mobileDrawer.classList.remove('active');
        mobileDrawerOverlay.classList.remove('active');
        document.body.style.overflow = '';
      };

      mobileMenuTrigger.addEventListener('click', openDrawer);
      mobileDrawerClose?.addEventListener('click', closeDrawer);
      mobileDrawerOverlay.addEventListener('click', closeDrawer);
      
      // Mobile Submenu Toggles
      const submenuTriggers = document.querySelectorAll('.mobile-drawer__submenu-trigger');
      
    // Desktop Megamenu Sub-item Interactions (Hover Intent + Click)
    const subItems = document.querySelectorAll('.custom-mega-sub-item');
    const subMenuTimers = {};

    subItems.forEach((item, index) => {
      const toggle = item.querySelector('.submenu-toggle-btn');
      const submenu = item.querySelector('.custom-mega-submenu');
      const itemId = 'sub-item-' + index;

      const openSubMenu = () => {
        clearTimeout(subMenuTimers[itemId]);
        // Close other sub-items in the same panel
        const siblings = item.parentElement.querySelectorAll('.custom-mega-sub-item');
        siblings.forEach(s => { if(s !== item) s.classList.remove('is-active'); });
        item.classList.add('is-active');
      };

      const closeSubMenu = () => {
        clearTimeout(subMenuTimers[itemId]);
        subMenuTimers[itemId] = setTimeout(() => {
          item.classList.remove('is-active');
        }, 1000); // Massive 1s hold for sub-item persistence
      };

      // Hover interactions
      item.addEventListener('mouseenter', () => {
        clearTimeout(subMenuTimers[itemId]);
        // If another one is already open, open this one slightly faster
        const hasOpen = document.querySelector('.custom-mega-sub-item.is-active');
        const delay = hasOpen ? 100 : 200; 
        subMenuTimers[itemId] = setTimeout(openSubMenu, delay);
      });

      item.addEventListener('mouseleave', closeSubMenu);

      // Keep open if mouse is in the 3rd column submenu
      if (submenu) {
        submenu.addEventListener('mouseenter', () => {
          clearTimeout(subMenuTimers[itemId]);
        });
        submenu.addEventListener('mouseleave', closeSubMenu);
      }

      // Click behavior for the arrow/button icon
      toggle?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        clearTimeout(subMenuTimers[itemId]);
        
        if (item.classList.contains('is-active')) {
          item.classList.remove('is-active');
        } else {
          openSubMenu();
        }
      });
    });

      submenuTriggers.forEach(trigger => {
        trigger.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          const parentItem = this.closest('.mobile-drawer__item');
          const wrapper = this.parentElement;
          
          let submenu = null;
          if (wrapper) {
            let next = wrapper.nextElementSibling;
            while (next) {
              if (next.classList && next.classList.contains('mobile-drawer__submenu')) {
                submenu = next;
                break;
              }
              next = next.nextElementSibling;
            }
          }
          
          if (!submenu && parentItem) {
            submenu = parentItem.querySelector(':scope > .mobile-drawer__submenu');
          }
          
          const icon = this.querySelector('svg');
          
          if(submenu) {
            submenu.classList.toggle('active');
            if(submenu.classList.contains('active')) {
               if(icon) icon.style.transform = 'rotate(180deg)';
            } else {
               if(icon) icon.style.transform = 'rotate(0deg)';
            }
          }
        });
      });
    }
  });
</script>
