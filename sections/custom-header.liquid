                                    </button>
                                  {% endif %}
                                </div>
                                {% if child_link.links.size > 0 %}
                                  <div class="mobile-drawer__submenu mobile-drawer__submenu--nested">
                                    <ul class="mobile-drawer__list">
                                      {% for grandchild_link in child_link.links %}
