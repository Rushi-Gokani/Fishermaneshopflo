{% assign section_id = section.id %}

{% style %}
  .ai-hero-slider-{{ section_id }} {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    display: block;
  }

  .ai-hero-slider__viewport-{{ section_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-hero-slider__track-{{ section_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-hero-slider__slide-{{ section_id }} {
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.background_color }};
    text-decoration: none;
    color: inherit;
  }

  .ai-hero-slider__image-wrapper-{{ section_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slider__image-{{ section_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .ai-hero-slider__desktop-image-{{ section_id }} {
    display: block;
  }

  .ai-hero-slider__mobile-image-{{ section_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slider__desktop-image-{{ section_id }} {
      display: none;
    }

    .ai-hero-slider__mobile-image-{{ section_id }} {
      display: block;
    }
  }

  .ai-hero-slider__placeholder-{{ section_id }} {
    width: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-slider__placeholder-{{ section_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-hero-slider__empty-state-{{ section_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-slider__content-{{ section_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ section.settings.text_color }};
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-hero-slider__heading-{{ section_id }} {
    font-size: {{ section.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ section.settings.text_color }};
  }

  .ai-hero-slider__subheading-{{ section_id }} {
    font-size: {{ section.settings.subheading_size }}px;
    margin: 0 0 24px;
    color: {{ section.settings.text_color }};
  }

  .ai-hero-slider__button-{{ section_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slider__button-{{ section_id }}:hover {
    background-color: {{ section.settings.button_hover_background }};
  }

  .ai-hero-slider__controls-{{ section_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .ai-hero-slider__dot-{{ section_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-hero-slider__dot-{{ section_id }}.active {
    opacity: 1;
  }

  .ai-hero-slider__arrow-{{ section_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ section.settings.arrow_background }};
    color: {{ section.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slider__arrow-{{ section_id }}:hover {
    background-color: {{ section.settings.arrow_hover_background }};
  }

  .ai-hero-slider__arrow-{{ section_id }}--prev {
    left: 20px;
  }

  .ai-hero-slider__arrow-{{ section_id }}--next {
    right: 20px;
  }

  .ai-hero-slider__arrow-{{ section_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slider__heading-{{ section_id }} {
      font-size: {{ section.settings.heading_size | times: 0.6 }}px;
    }

    .ai-hero-slider__subheading-{{ section_id }} {
      font-size: {{ section.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-hero-slider__arrow-{{ section_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-hero-slider__arrow-{{ section_id }}--prev {
      left: 10px;
    }

    .ai-hero-slider__arrow-{{ section_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<hero-slider-{{ section_id | replace: "_", "-" | downcase }} class="ai-hero-slider-{{ section_id }}">
  <div class="ai-hero-slider__viewport-{{ section_id }}">
    <div class="ai-hero-slider__track-{{ section_id }}">
      {% for block in section.blocks %}
        {% liquid
          assign current_image = block.settings.image
          assign current_mobile_image = block.settings.mobile_image
          assign current_show_content = block.settings.show_content
          assign current_heading = block.settings.heading
          assign current_subheading = block.settings.subheading
          assign current_button_text = block.settings.button_text
          assign current_button_link = block.settings.button_link
        %}

        {% if current_button_link != blank %}
          <a href="{{ current_button_link }}" class="ai-hero-slider__slide-{{ section_id }}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {% else %}
          <div class="ai-hero-slider__slide-{{ section_id }}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {% endif %}
          <div class="ai-hero-slider__image-wrapper-{{ section_id }}">
            {% if current_image %}
              <img
                src="{{ current_image | image_url: width: 2400 }}"
                alt="{{ current_image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ current_image.width }}"
                height="{{ current_image.height }}"
                class="ai-hero-slider__image-{{ section_id }} ai-hero-slider__desktop-image-{{ section_id }}"
              >
            {% endif %}

            {% if current_mobile_image %}
              <img
                src="{{ current_mobile_image | image_url: width: 1200 }}"
                alt="{{ current_mobile_image.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ current_mobile_image.width }}"
                height="{{ current_mobile_image.height }}"
                class="ai-hero-slider__image-{{ section_id }} ai-hero-slider__mobile-image-{{ section_id }}"
              >
            {% elsif current_image == blank %}
              <div class="ai-hero-slider__placeholder-{{ section_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                <div class="ai-hero-slider__empty-state-{{ section_id }}">
                  Add an image to slide {{ forloop.index }}
                </div>
              </div>
            {% endif %}
          </div>

          {% if current_show_content %}
            <div class="ai-hero-slider__content-{{ section_id }}">
              {% if current_heading != blank %}
                <h2 class="ai-hero-slider__heading-{{ section_id }}">{{ current_heading }}</h2>
              {% endif %}

              {% if current_subheading != blank %}
                <p class="ai-hero-slider__subheading-{{ section_id }}">{{ current_subheading }}</p>
              {% endif %}

              {% if current_button_text != blank and current_button_link != blank %}
                <span class="ai-hero-slider__button-{{ section_id }}">{{ current_button_text }}</span>
              {% elsif current_button_text != blank %}
                <span class="ai-hero-slider__button-{{ section_id }}">{{ current_button_text }}</span>
              {% endif %}
            </div>
          {% endif %}
        {% if current_button_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if section.settings.show_arrows %}
    <button class="ai-hero-slider__arrow-{{ section_id }} ai-hero-slider__arrow-{{ section_id }}--prev" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button class="ai-hero-slider__arrow-{{ section_id }} ai-hero-slider__arrow-{{ section_id }}--next" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  {% endif %}

  {% if section.settings.show_dots %}
    <div class="ai-hero-slider__controls-{{ section_id }}">
      {% for block in section.blocks %}
        <button class="ai-hero-slider__dot-{{ section_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</hero-slider-{{ section_id | replace: "_", "-" | downcase }}>

<script>
  (function() {
    class HeroSlider extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slideCount = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-hero-slider__track-{{ section_id }}');
        this.slides = this.querySelectorAll('.ai-hero-slider__slide-{{ section_id }}');
        this.dots = this.querySelectorAll('.ai-hero-slider__dot-{{ section_id }}');
        this.prevButton = this.querySelector('.ai-hero-slider__arrow-{{ section_id }}--prev');
        this.nextButton = this.querySelector('.ai-hero-slider__arrow-{{ section_id }}--next');
        this.slideCount = this.slides.length;

        if (this.slideCount <= 1) {
          if (this.prevButton) this.prevButton.style.display = 'none';
          if (this.nextButton) this.nextButton.style.display = 'none';
          return;
        }

        this.setupEventListeners();
        this.startAutoplay();
        
        // Listen for Shopify theme editor events
        document.addEventListener('shopify:block:select', (event) => {
          if (this.contains(event.target)) {
            const index = Array.from(this.slides).indexOf(event.target);
            if (index !== -1) {
              this.goToSlide(index);
              this.stopAutoplay();
            }
          }
        });
        document.addEventListener('shopify:block:deselect', (event) => {
          if (this.contains(event.target)) {
            this.startAutoplay();
          }
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.previousSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slideCount;
        this.updateSlider();
      }

      previousSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slideCount) % this.slideCount;
        this.updateSlider();
      }

      updateSlider() {
        if (!this.track) return;
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        const autoplayEnabled = {{ section.settings.autoplay | json }};
        const autoplaySpeed = {{ section.settings.autoplay_speed | times: 1000 }};

        if (autoplayEnabled && this.slideCount > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, autoplaySpeed);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        this.stopAutoplay();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    const customElementName = 'hero-slider-{{ section_id | replace: "_", "-" | downcase }}';
    if (!customElements.get(customElementName)) {
      customElements.define(customElementName, class extends HeroSlider {});
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Slider Blocks",
  "settings": [
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "checkbox",
